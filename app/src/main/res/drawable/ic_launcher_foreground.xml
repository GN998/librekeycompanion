<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Centered within the adaptive-icon safe zone (~66dp of the 108 canvas).
         A key shaft + bow over concentric contactless arcs, in white, echoing the
         uploaded logo's central mark. -->
